# ── Signing backend ── run `nub run init` for a guided setup ──────────────────
# SIGNER=frame | trezor | ledger | lattice | walletconnect   (default: frame)
# FRAME_URL=http://127.0.0.1:1248
# TREZOR_PATH=m/44'/60'/0'/0/0
# LEDGER_PATH=44'/60'/0'/0/0
# LATTICE_RELAY_URL=https://signing.gridpl.us
# LATTICE_DEVICE_ID=XXXXXX
# WALLETCONNECT_PROJECT_ID=...

# Abort if the connected account is not this address
# EXPECTED_VOTER=0x...

# ── Chain access ───────────────────────────────────────────────────────────────
# Read-only Ethereum RPC — single URL or comma-separated fallback list, tried in
# order (default: https://eth.drpc.org). Must serve eth_getLogs over ~10k blocks.
# RPC_URL=https://your-node.example.com,https://eth.drpc.org

# Gas fee overrides in gwei (defaults: tip 0.0001, max fee = base + 20% + tip)
# MAX_FEE_GWEI=1.5
# PRIORITY_FEE_GWEI=0.001

# Wallets that cap tx calldata (GridPlus Lattice ~1.5KB) get multicalls chunked
# TX_DATA_LIMIT_BYTES=1400

# ── Answers ────────────────────────────────────────────────────────────────────
# Answers precedence: ANSWERS_FILE → answers/<roundId>.json → installed addons
# ANSWERS_FILE=./my-answers.json

# Where round files (salts, tx hashes) are stored; point into a private
# version-controlled dir for git-backed backups (e.g. an addon checkout)
# ROUNDS_DIR=addons/my-addon/rounds

# GitHub API token (used by addons; falls back to `gh auth token`, then anonymous)
# GITHUB_TOKEN=ghp_...
